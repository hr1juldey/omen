"""Nabla training loop with per-component optimizers and surprise lr modulation.

Training paradigm:
1. Base model pre-trained on production scenes (shipped with Omen)
2. Per-scene episodic fine-tuning via separate correction network
3. Training data generated by Dr.Jit (Mitsuba differentiable rendering)
4. Nabla Python API: model.train(), loss.backward(), optimizer.step()

Per-Component Optimizers (Nabla pattern):
- Each component group has its own AdamW instance with independent lr
- Nabla AdamW takes single lr (no param groups) → multiple instances required
- model = optimizer.step() returns updated model (lazy execution)
"""

import logging
import os
import time

import numpy as np

try:
    import nabla as nb
    from nabla import nn
    import nabla.nn.functional as F
    NABLA_AVAILABLE = True
except ImportError:
    NABLA_AVAILABLE = False

from omen.config import OmenConfig

logger = logging.getLogger("omen.training.trainer")

# Training config defaults
DEFAULT_LR = 5e-5
DEFAULT_WEIGHT_DECAY = 1e-3
DEFAULT_GRADIENT_CLIP = 1.0
SIGREG_LAMBDA = 0.09

# Per-component base learning rates
COMPONENT_LRS = {
    "encoder": 5e-5,  # scene + render + cross_attn + confidence
    "decoder": 5e-5,
    "shared_expert": 5e-5,  # dense FFN
    "material_experts": 5e-5,  # only active when MoE ON
    "light_experts": 3e-5,  # only active when MoE ON
    "geometry_experts": 4e-5,  # only active when MoE ON
    "motion_experts": 5e-5,  # only active when MoE ON
    "ar_predictor": 5e-5,  # only active when AR ON
    "episodic_correction": 2e-2,  # 400x higher (matches Nabla LoRA pattern)
}


class OmenTrainer:
    """Nabla PyTorch-style trainer with per-component optimizers."""

    def __init__(
        self,
        model,
        config: OmenConfig = None,
        lr: float = DEFAULT_LR,
        weight_decay: float = DEFAULT_WEIGHT_DECAY,
    ):
        if not NABLA_AVAILABLE:
            raise ImportError("Nabla required for training")

        self.model = model
        self.config = config or OmenConfig()
        self.weight_decay = weight_decay
        self.iteration = 0

        # Validate config
        errors = self.config.validate()
        if errors:
            raise ValueError(f"Invalid config: {'; '.join(errors)}")

        # Create per-component optimizers
        self._optimizers: dict[str, nn.optim.AdamW] = {}
        self._component_params: dict[str, list] = {}
        self._setup_optimizers()

    def _setup_optimizers(self):
        """Create separate AdamW optimizer for each component group.

        Nabla constraint: AdamW takes single lr (no param groups like PyTorch).
        Solution: multiple AdamW instances, one per component group.
        This is the canonical Nabla pattern (LoRA example uses same approach).
        """
        c = self.config.components

        # Helper: collect params by prefix
        def collect(prefix: str) -> list:
            return [p for n, p in self.model.named_parameters() if n.startswith(prefix)]

        # Helper: create optimizer if params exist
        def create_opt(name: str, params: list, lr: float):
            if params and NABLA_AVAILABLE:
                self._component_params[name] = params
                self._optimizers[name] = nn.optim.AdamW(
                    params, lr=lr, weight_decay=self.weight_decay
                )

        # --- Core encoder group (shared optimizer) ---
        encoder_params = (
            collect("scene_encoder.") +
            collect("render_encoder.") +
            collect("cross_attn.") +
            collect("confidence_head.")
        )
        create_opt("encoder", encoder_params, COMPONENT_LRS["encoder"])

        # --- Decoder ---
        create_opt("decoder", collect("decoder."), COMPONENT_LRS["decoder"])

        # --- MoE components (only created when MoE enabled) ---
        if c.moe:
            create_opt("shared_expert", collect("moe.shared"), COMPONENT_LRS["shared_expert"])

            if c.moe_materials:
                create_opt("material_experts", collect("moe.materials"), COMPONENT_LRS["material_experts"])
            if c.moe_lights:
                create_opt("light_experts", collect("moe.lights"), COMPONENT_LRS["light_experts"])
            if c.moe_geometry:
                create_opt("geometry_experts", collect("moe.geometry"), COMPONENT_LRS["geometry_experts"])
            if c.moe_motion:
                create_opt("motion_experts", collect("moe.motion"), COMPONENT_LRS["motion_experts"])

        # --- ARPredictor (only created when AR enabled) ---
        if c.ar_predictor:
            ar_params = collect("ar_predictor.") + collect("delta_encoder.")
            create_opt("ar_predictor", ar_params, COMPONENT_LRS["ar_predictor"])

        # --- Episodic correction (always separate, higher lr) ---
        if c.episodic_correction:
            create_opt(
                "episodic_correction",
                collect("episodic."),
                COMPONENT_LRS["episodic_correction"],
            )

        logger.info(
            "Created %d optimizers: %s",
            len(self._optimizers),
            list(self._optimizers.keys()),
        )

    def _active_optimizers(self) -> list[tuple[str, nn.optim.AdamW]]:
        """Return list of (name, optimizer) for enabled components.

        Respects config switches. Disabled components have no optimizer
        or optimizer is skipped during iteration.
        """
        return [(n, opt) for n, opt in self._optimizers.items()]

    def _compute_lr(self, component_name: str, z_score: float = 0.0) -> float:
        """Compute learning rate with surprise modulation.

        Formula: lr = base_lr * (1.0 + scale * min(z_score, 5.0))

        Only applies when config.training.surprise_lr_modulation = True.
        """
        base_lr = COMPONENT_LRS.get(component_name, DEFAULT_LR)

        if not self.config.training.surprise_lr_modulation or z_score <= 0:
            return base_lr

        scale = self.config.training.surprise_lr_scale
        lr = base_lr * (1.0 + scale * min(z_score, 5.0))
        return lr

    def train_step(
        self,
        noisy,
        ground_truth,
        scene_graph,
        z_score: float = 0.0,
    ):
        """Run a single JEPA training step with per-component optimizers.

        JEPA paradigm: encode both noisy and clean renders into latent space,
        then train the model to predict the clean latent from the noisy latent.

        Args:
            noisy: (batch, H, W, 4) noisy render
            ground_truth: (batch, H, W, 4) clean ground truth
            scene_graph: dict of tensors
            z_score: surprise signal for lr modulation (from temporal.detect_surprise)

        Returns:
            dict with loss values and applied learning rates
        """
        self.model.train()

        # Forward pass (respects component switches via config)
        predicted_latent = self.model.encode(scene_graph, noisy)
        target_latent = self.model.encode(scene_graph, ground_truth)

        # Loss (respects regularization switches via config)
        total_loss, pred_loss, reg_loss = self.model.compute_loss(
            predicted_latent, target_latent, config=self.config
        )

        # Backward pass
        total_loss.backward()
        _clip_grad_norm(self.model.parameters(), DEFAULT_GRADIENT_CLIP)

        # Per-component optimizer steps
        applied_lrs = {}
        for name, optimizer in self._active_optimizers():
            lr = self._compute_lr(name, z_score)
            optimizer.lr = lr  # Nabla: direct lr assignment
            self.model = optimizer.step()  # Nabla: returns updated model
            applied_lrs[name] = lr

        self.model.zero_grad()
        self.iteration += 1

        return {
            "total_loss": float(total_loss.to_numpy().sum()),
            "pred_loss": float(pred_loss.to_numpy().sum()),
            "reg_loss": float(reg_loss.to_numpy().sum()),
            "iteration": self.iteration,
            "applied_lrs": applied_lrs,
            "z_score": z_score,
        }

    def save_checkpoint(self, path):
        """Save model state dict and config to disk."""
        os.makedirs(os.path.dirname(path), exist_ok=True)

        state_dict = self.model.state_dict()
        save_data = {
            "__iteration__": np.array(self.iteration),
            "__config__": np.array(self.config.to_dict(), dtype=object),  # Serialize config
        }
        for key, tensor in state_dict.items():
            save_data[key] = tensor.to_numpy()

        np.savez_compressed(path, **save_data)
        logger.info("Checkpoint saved: %s (iter %d)", path, self.iteration)

    def load_checkpoint(self, path):
        """Load model state dict and config from disk.

        Backward compatibility: if no config in checkpoint, use v1_dense() default.
        """
        npz_path = path if path.endswith(".npz") else path + ".npz"
        data = np.load(npz_path, allow_pickle=True)

        # Load config if present (backward compatible)
        if "__config__" in data.files:
            try:
                config_dict = data["__config__"].item()
                self.config = OmenConfig.from_dict(config_dict)
                logger.info("Loaded config from checkpoint")
            except Exception as e:
                logger.warning("Failed to load config, using default: %s", e)
                self.config = OmenConfig.v1_dense()
        else:
            logger.info("No config in checkpoint, using v1_dense() default")
            self.config = OmenConfig.v1_dense()

        # Rebuild state dict with Nabla tensors
        state_dict = {}
        for key in data.files:
            if key.startswith("__"):
                continue
            state_dict[key] = nb.Tensor.from_dlpack(data[key])
        self.model.load_state_dict(state_dict)
        self.iteration = int(data.get("__iteration__", 0))

        # Recreate optimizers with loaded config
        self._setup_optimizers()

        logger.info("Resumed from iteration %d with %d optimizers",
                    self.iteration, len(self._optimizers))


def _clip_grad_norm(parameters, max_norm):
    """Clip gradient norm to prevent explosion."""
    try:
        total_norm = 0.0
        for p in parameters:
            if p.grad is not None:
                total_norm += (p.grad ** 2).sum().to_numpy().item()
        total_norm = total_norm ** 0.5

        if total_norm > max_norm:
            scale = max_norm / (total_norm + 1e-6)
            for p in parameters:
                if p.grad is not None:
                    p.grad = p.grad * scale
    except Exception:
        pass  # Gradient clipping is best-effort
